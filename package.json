{
  "name": "careergpt",
  "version": "1.0.0",
  "description": "AI-powered Global Career Intelligence Platform",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:seed": "pnpm --filter @careergpt/database run seed",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "prisma": "^5.22.0",
    "turbo": "^1.13.3",
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "sharp"
    ]
  },
  "packageManager": "pnpm@10.34.4"
}
