# Database Connection
# Replace with Atlas URI if not using Docker
DATABASE_URL="mongodb://localhost:27017/careergpt?replicaSet=rs0&directConnection=true"

# Cache & Queues (Redis)
REDIS_URL="redis://localhost:6379"

# Backend Gateway Port
PORT=5000

# Authentication (JWT)
JWT_SECRET="super-secret-change-this-in-production-12345"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="super-refresh-secret-change-this-in-production-67890"
JWT_REFRESH_EXPIRES_IN="7d"

# OAuth Credentials (Optional for local dev, leave blank or replace)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# LLM & AI Integration
GEMINI_API_KEY="your-gemini-api-key"

# Frontend Configuration
NEXT_PUBLIC_API_URL="http://localhost:5000/api"
